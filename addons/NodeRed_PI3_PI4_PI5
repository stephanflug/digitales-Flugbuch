#!/bin/bash
set -eEuo pipefail

USERNAME="flugbuch"
BASE_DIR="/opt/addons/NodeRed"
DATA_DIR="$BASE_DIR/data"
SERVICE_FILE="/etc/systemd/system/nodered-docker.service"

# Absoluter Pfad des Scripts (für Selbst-Löschung)
SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")"

SUCCESS=0
CREATED_SERVICE=0

cleanup_on_failure() {
  set +e

  # Service zurückbauen, wenn wir ihn erzeugt haben
  if [ "$CREATED_SERVICE" -eq 1 ] && [ -f "$SERVICE_FILE" ]; then
    sudo systemctl disable --now nodered-docker.service >/dev/null 2>&1 || true
    sudo rm -f "$SERVICE_FILE" >/dev/null 2>&1 || true
    sudo systemctl daemon-reload >/dev/null 2>&1 || true
  fi
}

self_delete() {
  set +e
  rm -f "$SCRIPT_PATH" >/dev/null 2>&1 || sudo rm -f "$SCRIPT_PATH" >/dev/null 2>&1 || true
}

on_exit() {
  ec=$?
  if [ "$SUCCESS" -eq 1 ] && [ "$ec" -eq 0 ]; then
    return
  fi

  echo "-----------------------------------------------------------------"
  echo "Installation NICHT erfolgreich (Exit-Code: $ec)."
  echo "Cleanup + Script wird gelöscht: $SCRIPT_PATH"
  echo "-----------------------------------------------------------------"

  cleanup_on_failure
  self_delete
}
trap on_exit EXIT

# === 0. Nur Raspberry Pi 3–5 erlauben ===
MODEL="$(tr -d '\0' </proc/device-tree/model 2>/dev/null || true)"
if ! echo "$MODEL" | grep -Eq 'Raspberry Pi (3|4|5)'; then
  echo "FEHLER: Nicht unterstützte Hardware: $MODEL"
  echo "Dieses Setup ist nur für Raspberry Pi 3, 4 oder 5 erlaubt."
  exit 1
fi

# === 1. Docker muss da sein + laufen ===
if ! command -v docker >/dev/null 2>&1; then
  echo "FEHLER: docker ist nicht installiert oder nicht im PATH."
  exit 1
fi
if ! sudo systemctl is-active --quiet docker; then
  echo "FEHLER: Docker Service läuft nicht. Starte mit: sudo systemctl start docker"
  exit 1
fi

# === 2. Port 1881 frei? ===
if sudo ss -ltn | awk '{print $4}' | grep -qE '(:|\.)1881$'; then
  echo "FEHLER: Port 1881 ist bereits belegt."
  exit 1
fi

# === 3. Compose-Command bestimmen ===
COMPOSE_CMD=""
if docker compose version >/dev/null 2>&1; then
  COMPOSE_CMD="docker compose"
elif command -v docker-compose >/dev/null 2>&1; then
  COMPOSE_CMD="docker-compose"
else
  echo "FEHLER: Weder 'docker compose' noch 'docker-compose' gefunden."
  exit 1
fi

# === 4. Containername-Kollision verhindern ===
if sudo docker ps -a --format '{{.Names}}' | grep -qx 'nodered'; then
  echo "FEHLER: Es existiert bereits ein Container mit dem Namen 'nodered'."
  echo "Bitte entfernen/umbenennen, oder passe container_name im Compose an."
  exit 1
fi

# === 5. Ordner anlegen ===
sudo mkdir -p "$DATA_DIR"

# === 6. UID/GID + dialout GID ===
NR_UID="1000"
NR_GID="1000"
if id "$USERNAME" >/dev/null 2>&1; then
  NR_UID="$(id -u "$USERNAME")"
  NR_GID="$(id -g "$USERNAME")"
  sudo chown -R "$USERNAME:$USERNAME" "$BASE_DIR"
else
  sudo chown -R 1000:1000 "$BASE_DIR" || true
fi

DIALOUT_GID="$(getent group dialout | awk -F: '{print $3}')"
[ -z "$DIALOUT_GID" ] && DIALOUT_GID="20"

# === 7. .env schreiben ===
sudo tee "$BASE_DIR/.env" > /dev/null <<EOF
TZ=Europe/Vienna
NR_UID=$NR_UID
NR_GID=$NR_GID
DIALOUT_GID=$DIALOUT_GID
EOF

# === 8. USB/Serial Devices dynamisch erkennen ===
DEVICE_LINES=""
for d in /dev/ttyUSB* /dev/ttyACM*; do
  if [ -e "$d" ]; then
    DEVICE_LINES+="      - \"$d:$d\"\n"
  fi
done

# === 9. docker-compose.yml schreiben (Volumes absolut unter /opt/addons/NodeRed) ===
# Backup falls schon vorhanden
if [ -f "$BASE_DIR/docker-compose.yml" ]; then
  TS="$(date +%Y%m%d%H%M%S)"
  sudo cp -a "$BASE_DIR/docker-compose.yml" "$BASE_DIR/docker-compose.yml.bak.$TS"
fi

if [ -n "$DEVICE_LINES" ]; then
  sudo tee "$BASE_DIR/docker-compose.yml" > /dev/null <<EOF
services:
  nodered:
    image: nodered/node-red:latest
    container_name: nodered
    ports:
      - "1881:1880"
    environment:
      - TZ=\${TZ}
    user: "\${NR_UID}:\${NR_GID}"
    group_add:
      - "\${DIALOUT_GID}"
    devices:
$(printf "$DEVICE_LINES")
      # Für "echtes" USB (libusb/HID) optional:
      # - "/dev/bus/usb:/dev/bus/usb"
    volumes:
      - $DATA_DIR:/data
    restart: unless-stopped
EOF
else
  sudo tee "$BASE_DIR/docker-compose.yml" > /dev/null <<EOF
services:
  nodered:
    image: nodered/node-red:latest
    container_name: nodered
    ports:
      - "1881:1880"
    environment:
      - TZ=\${TZ}
    user: "\${NR_UID}:\${NR_GID}"
    group_add:
      - "\${DIALOUT_GID}"
    # Keine /dev/ttyUSB* oder /dev/ttyACM* erkannt.
    # Wenn du später USB/Serial nutzt, ergänze hier z.B.:
    # devices:
    #   - "/dev/ttyUSB0:/dev/ttyUSB0"
    #   - "/dev/ttyACM0:/dev/ttyACM0"
    # Für "echtes" USB (libusb/HID) optional:
    #   - "/dev/bus/usb:/dev/bus/usb"
    volumes:
      - $DATA_DIR:/data
    restart: unless-stopped
EOF
fi

# === 10. systemd Service anlegen ===
sudo tee "$SERVICE_FILE" > /dev/null <<EOF
[Unit]
Description=Node-RED (Docker Compose) on port 1881
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=$BASE_DIR
ExecStart=/bin/bash -lc '$COMPOSE_CMD up -d'
ExecStop=/bin/bash -lc '$COMPOSE_CMD down'
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
EOF
CREATED_SERVICE=1

sudo systemctl daemon-reload
sudo systemctl enable --now nodered-docker.service

# === 11. Pull + Start ===
sudo /bin/bash -lc "cd '$BASE_DIR' && $COMPOSE_CMD pull && $COMPOSE_CMD up -d"

IP="$(hostname -I | awk '{print $1}')"
echo "-----------------------------------------------------------------"
echo "Fertig! Node-RED läuft:"
echo "  URL:  http://$IP:1881"
echo "  Data: $DATA_DIR -> /data"
echo "  Logs: sudo docker logs -f nodered"
echo "-----------------------------------------------------------------"

SUCCESS=1
exit 0
